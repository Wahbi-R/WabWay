{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/board/**",
              "components/core/**",
              "components/feedback/**",
              "components/files/**",
              "components/forms/**",
              "components/itinerary/**",
              "components/money/**",
              "components/navigation/**",
              "ui_kits/wabway-desktop/**",
              "ui_kits/wabway-desktop/sections/**",
              "ui_kits/wabway-mobile/**",
              "ui_kits/wabway-mobile/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Lora|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Lora, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|primary|secondary|accent|success|warning|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'primary' | 'secondary' | 'accent' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BalanceSummaryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:youOwe|youAreOwed|currency|key|ref|className|style|children)$/]",
        "message": "<BalanceSummaryCard> doesn't accept that prop. Declared props: youOwe, youAreOwed, currency."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|action|children|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: icon, tone, action, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|danger)$/]",
        "message": "<Banner> tone must be one of 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onChange|iconBase|key|ref|className|style|children)$/]",
        "message": "<BottomNav> doesn't accept that prop. Declared props: active, onChange, iconBase."
